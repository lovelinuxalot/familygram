# Copy this file to scripts/ship.env and fill in the four values.
# scripts/ship.env is gitignored.

# Production Worker URL printed by `wrangler deploy`.
API_BASE="https://YOUR-WORKER.YOUR-HANDLE.workers.dev"

# Your Ory project URL. Same one you've been using in dev.
ORY_BASE="https://YOUR-ORY-SLUG.projects.oryapis.com"

# App Store Connect API key. See scripts/RELEASE.md for how to create one.
# The .p8 file itself must live at:
#   ~/.appstoreconnect/private_keys/AuthKey_${ASC_API_KEY_ID}.p8
ASC_API_KEY_ID="ABCDE12345"
ASC_API_ISSUER_ID="00000000-0000-0000-0000-000000000000"
