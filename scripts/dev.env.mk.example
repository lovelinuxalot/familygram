# Personal dev overrides for the top-level Makefile. Copy to dev.env.mk
# (which is gitignored) and edit. The Makefile `-include`s it if present, so
# any variable set here overrides the defaults baked into the Makefile.
#
#   cp scripts/dev.env.mk.example scripts/dev.env.mk
#
# Common things to set:
#
#   DEV_ORY_BASE := https://<your-ory-slug>.projects.oryapis.com
#
# Defaults in the Makefile (DEV_API_BASE, DEV_API_BASE_ANDROID) usually don't
# need overriding for daily dev — they assume `make worker` on :8787.
